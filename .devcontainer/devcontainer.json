{
  "name": "OpenTelemetry Demo Light",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "frontend",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    8080,
    4317,
    4318
  ],
  "portsAttributes": {
    "8080": { "label": "Frontend", "onAutoForward": "openBrowser" },
    "4317": { "label": "OTel Collector gRPC", "onAutoForward": "silent" },
    "4318": { "label": "OTel Collector HTTP", "onAutoForward": "silent" }
  },
  "postCreateCommand": "echo '✅ OpenTelemetry Demo Light is starting...' && sleep 10 && echo '🔭 Frontend: http://localhost:8080' && echo '📊 k6 logs: docker compose logs -f load-generator'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "golang.go",
        "redhat.java",
        "ms-python.python",
        "rust-lang.rust-analyzer",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  }
}
