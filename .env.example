# OpenTelemetry Demo Light - Environment Configuration
# Copy this file to .env and modify as needed.

# =============================================================================
# OTel Collector / Backend
# =============================================================================
# Default: services send to the collector in the compose network.
# To send to an external backend, set the OTLP endpoint and headers below.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Uncomment and set for cloud backends (e.g., Grafana Cloud, Dynatrace):
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-token>
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp

# =============================================================================
# Service Addresses (internal Docker network)
# =============================================================================
PRODUCT_CATALOG_ADDR=product-catalog:3550
CART_ADDR=cart:7070
CHECKOUT_ADDR=checkout:5050
PAYMENT_ADDR=payment:6060

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=otel
POSTGRES_PASSWORD=otel

# =============================================================================
# Valkey (Redis-compatible)
# =============================================================================
VALKEY_ADDR=valkey:6379

# =============================================================================
# Load Generator
# =============================================================================
LOCUST_USERS=5
LOCUST_SPAWN_RATE=1
# Set to true for headless mode (no web UI):
# LOCUST_HEADLESS=true
